# Copy this file to terraform.tfvars and adjust to your needs.
# terraform.tfvars is git-ignored by convention since it may contain
# environment-specific / sensitive values.

location            = "eastus"
resource_group_name = "rg-selfhost-vps"
prefix               = "selfhost"
vm_size              = "Standard_B2ms"
admin_username       = "azureadmin"
ssh_public_key_path  = "~/.ssh/id_rsa.pub"

os_disk_size_gb      = 128
os_disk_storage_type = "Premium_LRS"

# IMPORTANT: restrict this to your actual IP, e.g. "203.0.113.5/32"
# Find your IP with: curl -s ifconfig.me
allowed_ssh_source = "*"
